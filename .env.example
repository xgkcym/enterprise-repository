# Runtime environment
APP_ENV=development
DEBUG=false
SERVER_HOST=127.0.0.1
SERVER_PORT=1016

# Database bootstrap
DATABASE_AUTO_CREATE=false

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1800

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

# Static files
SERVE_PUBLIC_FILES=false
PUBLIC_URL_PATH=/public
# PUBLIC_DIR=D:/python/agent_project/rag-agent/service/public

# Uploads
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=txt,docx,md,pdf,xlsx,csv,pptx,json,png,jpg,jpeg,bmp,gif
