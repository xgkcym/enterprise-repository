# First deployment guide
# Local Docker: usually only check JWT_SECRET_KEY, OPENAI_API_KEY or DEEPSEEK_API_KEY, and DOCKER_MILVUS_URI.
# Cloud server: additionally change APP_ENV, DOCKER_APP_ENV, FRONTEND_PORT, CORS_ALLOW_ORIGINS, and POSTGRES_PASSWORD.

# 1) First look here
APP_ENV=development
DOCKER_APP_ENV=development
FRONTEND_PORT=8080
DEBUG=false
JWT_SECRET_KEY=replace-with-a-long-random-secret
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DOCKER_MILVUS_URI=http://host.docker.internal:19530

# 2) Usually keep these defaults
SERVER_HOST=127.0.0.1
SERVER_PORT=1016
DATABASE_AUTO_CREATE=false
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1800
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept
SERVE_PUBLIC_FILES=false
PUBLIC_URL_PATH=/public
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=txt,docx,md,pdf,xlsx,csv,pptx,json,png,jpg,jpeg,bmp,gif
DELETE_FILE=false
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
BOOTSTRAP_ADMIN_DEPT_ID=1
BOOTSTRAP_ADMIN_DEPT_NAME=默认部门
BOOTSTRAP_ADMIN_ROLE_ID=1
BOOTSTRAP_ADMIN_ROLE_NAME=默认权限角色

# 3) Database and collection defaults
POSTGRES_DB=rag_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_NAME=rag_agent
MONGODB_DB_NAME=rag_agent
VECTOR_TABLE_NAME=rag_doc
DOC_COLLECTION_NAME=rag_doc
QA_COLLECTION_NAME=rag_qa

# 4) Core RAG settings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
BM25_RETRIEVAL_MODE=lite
RETRIEVER_TOP_K=5
RERANKER_TOP_K=5
RETRIEVAL_MIN_SCORE=0.1
RERANKER_MIN_SCORE=0.1
RERANKER_TYPE=cross-encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 5) Model provider defaults
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_URL=https://api.deepseek.com
ZHIPUAI_API_KEY=
HF_TOKEN=

# 6) Agent defaults
AGENT_MAX_STEPS=10
AGENT_CHAT_HISTORY_LIMIT=8
AGENT_OUTPUT_LEVEL=standard

# 7) Long-term memory defaults
MEMORY_ENABLED=false
MEMORY_BACKEND=milvus
MEMORY_TOP_K=3
MEMORY_CONTEXT_LIMIT=3
MEMORY_RECALL_MIN_SCORE=0.35
MEMORY_WRITE_ENABLED=false
MEMORY_WRITE_MIN_IMPORTANCE=0.65
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=long_term_memory
MILVUS_CONSISTENCY_LEVEL=Strong
MILVUS_SEARCH_METRIC=COSINE
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_VECTOR_DIM=1024

# 8) Optional tuning
OCR_LANG=ch
OCR_MIN_SCORE=0.5
OCR_SERVICE_URL=http://127.0.0.1:8016
OCR_SERVICE_TIMEOUT_SECONDS=30
TXT_CHUNK_SIZE=500
TXT_CHUNK_OVERLAP=50
PDF_CHUNK_SIZE=500
PDF_CHUNK_OVERLAP=50
EXCEL_CHUNK_SIZE=500
EXCEL_CHUNK_OVERLAP=50
MAX_RETRIES=3
MAX_TIMEOUT=60
