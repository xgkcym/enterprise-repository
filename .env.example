# Single env template for Docker deployment and local development.
# Local Docker: usually only check JWT_SECRET_KEY, OPENAI_API_KEY or DEEPSEEK_API_KEY.
# Cloud server: additionally change APP_ENV, DOCKER_APP_ENV, FRONTEND_PORT, CORS_ALLOW_ORIGINS, and POSTGRES_PASSWORD.
# DOCKER_MILVUS_URI now defaults to the bundled single-container Milvus service inside docker-compose.

# 1) First look here
APP_ENV=development
DOCKER_APP_ENV=development
FRONTEND_PORT=8080
DEBUG=false
JWT_SECRET_KEY=replace-with-a-long-random-secret
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DOCKER_MILVUS_URI=http://milvus:19530
NPM_REGISTRY=https://registry.npmjs.org/

# 2) Usually keep these defaults
SERVER_HOST=127.0.0.1
SERVER_PORT=1016
DATABASE_AUTO_MIGRATE=false
DATABASE_AUTO_CREATE=false
DATABASE_AUTO_INIT_ON_STARTUP=true
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1800
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept
SERVE_PUBLIC_FILES=false
PUBLIC_URL_PATH=/public
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=txt,docx,md,pdf,xlsx,csv,pptx,json,png,jpg,jpeg,bmp,gif
DELETE_FILE=false
BOOTSTRAP_SEED_ENABLED=true
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
BOOTSTRAP_ADMIN_DEPT_ID=1
BOOTSTRAP_ADMIN_DEPT_NAME=默认部门
BOOTSTRAP_ADMIN_ROLE_ID=1
BOOTSTRAP_ADMIN_ROLE_NAME=默认权限角色

BOOTSTRAP_SEED_DEPARTMENTS_JSON=
BOOTSTRAP_SEED_ROLES_JSON=
BOOTSTRAP_SEED_USERS_JSON=
# Optional: load departments / roles / users from a JSON seed file on first start.
# Example: BOOTSTRAP_SEED_FILE=db/seed/bootstrap_seed.example.json
BOOTSTRAP_SEED_FILE=

# 3) Database and collection defaults
POSTGRES_DB=rag_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_NAME=rag_agent
DATABASE_STRING=postgresql://postgres:postgres@localhost:5432/rag_agent
DATABASE_ASYNC_STRING=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_agent
MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=rag_agent
VECTOR_TABLE_NAME=rag_doc
DOC_COLLECTION_NAME=rag_doc
QA_COLLECTION_NAME=rag_qa

# 4) Core RAG settings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
BM25_RETRIEVAL_MODE=lite
RETRIEVER_TOP_K=5
RERANKER_TOP_K=5
RETRIEVAL_MIN_SCORE=0.1
RERANKER_MIN_SCORE=0.1
RERANKER_TYPE=cross-encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_MAX_LEN=512

# 5) Model provider defaults
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_URL=https://api.deepseek.com
ZHIPUAI_API_KEY=
HF_TOKEN=

# 6) Agent defaults
AGENT_MAX_STEPS=10
AGENT_CHAT_HISTORY_LIMIT=8
AGENT_OUTPUT_LEVEL=standard

# 7) Long-term memory defaults
MEMORY_ENABLED=false
MEMORY_BACKEND=milvus
MEMORY_TOP_K=3
MEMORY_CONTEXT_LIMIT=3
MEMORY_RECALL_MIN_SCORE=0.35
MEMORY_WRITE_ENABLED=false
MEMORY_WRITE_MIN_IMPORTANCE=0.65
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=long_term_memory
MILVUS_CONSISTENCY_LEVEL=Strong
MILVUS_SEARCH_METRIC=COSINE
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_VECTOR_DIM=1024

# 7.1) Docker Milvus service defaults
MILVUS_IMAGE=milvusdb/milvus:v2.5.26
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091

# 8) Financial fact graph / Graph-RAG
GRAPH_ENABLED=false
GRAPH_ENTITY_COLLECTION_NAME=graph_entities
GRAPH_FACT_COLLECTION_NAME=graph_facts
GRAPH_MAX_FACTS_PER_CHUNK=12
GRAPH_QUERY_TOP_K=6
GRAPH_QUERY_MAX_CANDIDATES=60

# 9) Optional tuning
OCR_SERVICE_URL=http://127.0.0.1:8016
OCR_SERVICE_TIMEOUT_SECONDS=120
OCR_LANG=ch
OCR_MIN_SCORE=0.5
OCR_CLIENT_MAX_CONCURRENCY=1
OCR_INFERENCE_RECOVERY_RETRIES=1
OCR_MAX_IMAGE_SIDE=1600
OCR_DET_LIMIT_SIDE_LEN=960
OCR_SUBPROCESS_FALLBACK_ENABLED=true
OCR_SUBPROCESS_TIMEOUT_SECONDS=300
TXT_CHUNK_SIZE=500
TXT_CHUNK_OVERLAP=50
TXT_MIN_CHUNK_SIZE=100
PDF_CHUNK_SIZE=500
PDF_CHUNK_OVERLAP=50
DOCX_CHUNK_SIZE=500
DOCX_CHUNK_OVERLAP=50
DOCX_MIN_CHUNK_SIZE=100
MD_CHUNK_SIZE=500
MD_CHUNK_OVERLAP=50
MD_MIN_CHUNK_SIZE=100
PPTX_CHUNK_SIZE=500
PPTX_CHUNK_OVERLAP=50
JSON_CHUNK_SIZE=500
JSON_CHUNK_OVERLAP=50
JSON_MIN_CHUNK_SIZE=100
IMAGE_CHUNK_SIZE=500
IMAGE_CHUNK_OVERLAP=50
CONTEXT_MAX_LEN=4000
EXCEL_CHUNK_SIZE=500
EXCEL_CHUNK_OVERLAP=50
EXCEL_MIN_CHUNK_SIZE=100
MAX_RETRIES=3
MAX_TIMEOUT=60
